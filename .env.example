# XRPName MCP Server — environment template (Phase 1)
# Copy to .env and adjust. Never commit .env.

# Backend REST API (pure consumer — no DB access)
XRPDOMAINS_API_BASE=https://xrpdomains.xyz

# XRPL network
XRPL_WSS_URL=wss://xrplcluster.com

# Treasury (registration Payment destination) — mirrors v3/networks-mainnet.js
XRPDOMAINS_TREASURY_ADDRESS=raAyazbgEkwzLByXipQuPLWFfnsPS1v1q9

# Pricing (mirrors v3/networks-mainnet.js + search.html tiers)
PRICING_BASE_PRICE_XRP=10
PRICING_DISCOUNT_PERCENT=50

# Redis — optional in Buoc 0; falls back to in-memory cache when unset.
# Also backs rate limiting (atomic INCR). In-memory works for single-instance dev.
# REDIS_URL=redis://localhost:6379

# Rate limiting (§12.1). Per fixed window; keyed by authed address, else IP.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_READ_PER_MIN=60
RATE_LIMIT_UNAUTH_PER_MIN=30
RATE_LIMIT_WINDOW_SEC=60

# DEV ONLY — fake authenticated XRPL address until OAuth (Buoc 3) ships.
# Used by get_portfolio / get_pending_offers when no address arg is given.
# DEV_ADDRESS=rXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

LOG_LEVEL=info
PORT=3000
